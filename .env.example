# =============================================================================
# Research Society — environment template (Qwen Cloud / DashScope)
# =============================================================================
# Copy this file, then put in your real key:
#
#   Local (backend only):  cp .env.example backend/.env
#   Alibaba Cloud Docker:  cp .env.example .env
#
# Get a pay-as-you-go key (sk-... NOT sk-sp-...):
#   https://home.qwencloud.com/api-keys
# Docs: https://docs.qwencloud.com
# =============================================================================

# --- Required: DashScope pay-as-you-go API key for Qwen text ---
# Use pay-as-you-go (sk-...). Do NOT use Token Plan keys (sk-sp-...) here —
# those only work with the token-plan base URL and are not for backend scripts.
API_KEY=sk-your-dashscope-api-key

# International / Singapore (default for most hackathon accounts):
API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# China (Beijing):
# API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# US (Virginia):
# API_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Text model for debate, maps, and fact-check
# Hackathon catalog: qwen3.7-plus | qwen3.7-max | qwen3.6-flash
MODEL_NAME=qwen3.7-max

# OpenAlex / Unpaywall contact (paper PDF lookup; free, no paid API key)
UNPAYWALL_EMAIL=you@example.com

# Debate
MAX_ROUNDS=5
CONSENSUS_THRESHOLD=0.8
LLM_TIMEOUT=120

# Docker / Alibaba Cloud only (host port → container :8000)
APP_PORT=80

# Logging
LOG_LEVEL=INFO

# US (Virginia) ECS — uncomment instead of intl base URL above:
# API_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
