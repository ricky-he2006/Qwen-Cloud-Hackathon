# Copy to backend/.env:
#   cp .env.example .env
#
# Full comments: see repo root .env.example
# Also accepted: DASHSCOPE_API_KEY instead of API_KEY

# --- Qwen Cloud (pay-as-you-go sk-... key) ---
API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# US Virginia ECS:
# API_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
API_KEY=sk-your-dashscope-api-key
MODEL_NAME=qwen3.7-plus

UNPAYWALL_EMAIL=you@example.com
MAX_ROUNDS=5
CONSENSUS_THRESHOLD=0.8
LLM_TIMEOUT=120
LOG_LEVEL=INFO

# --- Local Ollama instead (no cloud key) ---
# API_BASE_URL=http://localhost:11434/v1
# API_KEY=not-needed
# MODEL_NAME=qwen3.6:latest
